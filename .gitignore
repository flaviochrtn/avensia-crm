# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
# .env.example est commité volontairement


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Notion raw exports (originals preserved locally, not needed in git)
data/raw/
data/clean/backups/

# Python
__pycache__/
*.pyc
